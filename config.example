# Example config for audio-utils
#
# Install (XDG):
#   mkdir -p "${XDG_CONFIG_HOME:-$HOME/.config}/audio-utils"
#   cp config.example "${XDG_CONFIG_HOME:-$HOME/.config}/audio-utils/config"
#
# Environment variables already set in the shell take precedence over this file.

AUDIO_UTILS_ROOTS="$HOME/Music $HOME/Downloads"

# WAV2FLAC_ROOTS="$HOME/Music"

# --- Lossy quality (MP3 default stays v0) ---
# AUDIO_UTILS_MP3_QUALITY=v0
# FLAC2MP3_QUALITY=v0
# AUDIO_UTILS_OPUS_QUALITY=128
# AUDIO_UTILS_AAC_QUALITY=192
# AUDIO_UTILS_VORBIS_QUALITY=q6
# LOSSY_NO_RESAMPLE=1

# --- TAK (see docs/tak.md) ---
# AUDIO_UTILS_TAKC=/path/to/Takc.exe
# AUDIO_UTILS_TAK_PRESET=p2

# --- Optical ---
# AUDIO_UTILS_DVD_DEVICE=/dev/sr0
# AUDIO_UTILS_CD_DEVICE=/dev/sr0
# AUDIO_UTILS_BD_DEVICE=/dev/sr0
# AUDIO_UTILS_MAKEMKV=/usr/bin/makemkvcon
# AACS KEYDB.cfg is operator-supplied at $XDG_CONFIG_HOME/aacs/KEYDB.cfg (never vendored)

# XDG overrides (optional):
# XDG_CONFIG_HOME="$HOME/.config"
# XDG_STATE_HOME="$HOME/.local/state"
# XDG_CACHE_HOME="$HOME/.cache"
