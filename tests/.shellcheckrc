# Test suite. SCRIPTDIR/.. lets tests/<tier>/*.test.sh resolve the
# "# shellcheck source=../harness.sh" directives regardless of cwd.
source-path=SCRIPTDIR
source-path=SCRIPTDIR/..
external-sources=true
shell=bash

# The harness intentionally sets T inside the per-test subshell; tests
# reading $T afterwards are the design, not a lost-modification bug.
disable=SC2030,SC2031

# Tests define stub globals/functions consumed by sourced lib files or
# invoked indirectly (run_parallel callbacks), which look unused to
# shellcheck's static view.
disable=SC2034,SC2329
